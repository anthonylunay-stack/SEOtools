    {
      "parameters": {
        "jsCode": "const sheets = {};\n\nfor (const item of $input.all()) {\n  const name = item.json.sheetName ?? 'Sheet1';\n  if (!sheets[name]) sheets[name] = [];\n  // Remove sheetName from row data to avoid polluting the data sent to the AI\n  const { sheetName, ...rowData } = item.json;\n  sheets[name].push(rowData);\n}\n\n// Limit to last 100 rows per sheet to avoid token overflow\nreturn Object.entries(sheets).map(([name, rows]) => ({\n  json: {\n    sheetName: name,\n    rowCount: rows.length,\n    rows: rows.slice(-100)\n  }\n}));\n"
      },
